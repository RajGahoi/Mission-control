{
  "manifest_version": 3,
  "name": "Mission Control — Distraction Replay",
  "version": "1.0.0",
  "description": "Track focus missions across your browser tabs and replay exactly how your attention drifted, mission by mission.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Mission Control"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "alarms", "notifications", "offscreen"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
